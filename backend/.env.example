# --- Database ---
# En local puedes dejarlo vacío y usará SQLite (./short_radar.db)
# En Render, Render lo inyecta automáticamente
DATABASE_URL=

# --- LLM (opcional pero recomendado para explicaciones de calidad) ---
# Si no la pones, la app usa una plantilla determinista en su lugar
ANTHROPIC_API_KEY=

# --- FRED (opcional, para datos macro mejores) ---
# Gratis en https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# --- Configuración general ---
ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000

# --- Scoring (pesos, 0-1, deben sumar 1) ---
WEIGHT_TECHNICAL=0.30
WEIGHT_NEWS=0.25
WEIGHT_FUNDAMENTAL=0.20
WEIGHT_MACRO=0.15
WEIGHT_LIQUIDITY=0.10

# --- Universo (cuántos tickers analizar por mercado en cada job) ---
# Bajos para free tier (limita tiempo de ejecución)
MAX_TICKERS_PER_MARKET=80

# --- Auth simple para endpoints admin (opcional) ---
ADMIN_TOKEN=change-me-in-prod
